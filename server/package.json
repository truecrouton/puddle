{
  "name": "puddle",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Home automation with MQTT",
  "main": "./dist/main.js",
  "scripts": {
    "build:all": "npm run build:server && npm run build:webapp",
    "build:server": "npm run build:only:server && npm run build:only:plugins",
    "build:only:server": "npm run generate:types && tsc --noEmit && esbuild src/main.ts --bundle --platform=node --target=node22 --minify --external:better-sqlite3 --outfile=dist/main.js",
    "build:only:plugins": "tsc --noEmit && esbuild \"src/plugin/**/*.ts\" --bundle --platform=node --target=node22 --minify --outdir=dist/plugin --outbase=src/plugin",
    "build:webapp": "npm run parcel:build --prefix=../webapp",
    "dev": "npm run generate:types && tsx watch src/main.ts",
    "generate:types": "tsx src/routes/schemas/generate-types.ts",
    "migration:create": "knex migrate:make",
    "migrate:latest": "knex migrate:latest",
    "migrate:reset": "npm run migrate:rollback && npm run migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "start": "node ./dist/main.js",
    "test": "NODE_ENV=test lab --typescript src/test",
    "type-check": "tsc --noEmit"
  },
  "author": "Pin Tan",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/cookie": "^12.0.1",
    "@hapi/hapi": "^21.3.2",
    "@hapi/hoek": "^11.0.2",
    "@hapi/inert": "^7.1.0",
    "@types/node-schedule": "^2.1.0",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "joi": "^17.9.2",
    "lru-cache": "^11.2.7",
    "mqtt": "^4.3.7",
    "node-schedule": "^2.1.1",
    "ohm-js": "^17.5.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@hapi/code": "^9.0.3",
    "@hapi/lab": "^25.1.2",
    "@ngneat/falso": "^6.4.0",
    "@types/better-sqlite3": "^7.6.4",
    "@types/hapi__cookie": "^12.0.2",
    "@types/node": "^20.2.4",
    "@types/suncalc": "^1.9.0",
    "esbuild": "^0.28.0",
    "joi-to-typescript": "^4.15.0",
    "knex": "^2.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  }
}