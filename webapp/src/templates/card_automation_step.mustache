{{#automations}}
{{#kind_is_if}}
<div class="card mb-3">
    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">if (</a>
            <a href="javascript:void(0);" class="text-decoration-none" data-bs-toggle="modal" data-bs-target="#modalExpressionEdit" data-expression-id="{{expression_id}}">
                {{expression}}
            </a>
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">) {</a>
        </h5>
    </div>
    <ul class="list-group list-group-flush font-monospace">
        {{#nested_expressions}}
        {{> conditional_steps}}
        {{/nested_expressions}}
        <li class="list-group-item">
            <a class="fs-4" href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#modalConditional" data-expression-id="{{expression_id}}"><i class="bi bi-plus-circle-fill"></i></a>
        </li>
    </ul>
    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">} else {</a>
        </h5>
    </div>
    <ul class="list-group list-group-flush font-monospace">
        {{#nested_expressions}}
        {{> else_steps}}
        {{/nested_expressions}}
        <li class="list-group-item">
            <a class="fs-4" href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#modalConditional" data-is-else-step="1" data-expression-id="{{expression_id}}"><i class="bi bi-plus-circle-fill"></i></a>
        </li>
    </ul>
    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">}</a>
        </h5>
    </div>
</div>
{{/kind_is_if}}
{{#kind_is_publish}}
<div class="card mb-3">
    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">publish ({{topic}} {{message}})</a>
        </h5>
    </div>
</div>
{{/kind_is_publish}}
{{#kind_is_notify}}
<div class="card mb-3">
    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">notify ()</a>
        </h5>
    </div>
</div>
{{/kind_is_notify}}
