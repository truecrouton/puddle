    <div class="card-body pb-0">
        <h5 class="card-title font-monospace pb-2">
            <a href="javascript:void(0);" class="text-decoration-none pdl-color-code" data-bs-toggle="modal" data-bs-target="#modalExpression" data-expression-id="{{expression_id}}">wait ()</a>
        </h5>
    </div>
</div>
{{/kind_is_wait}}
{{/automations}}
